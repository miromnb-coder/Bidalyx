{
  "expo": {
    "name": "Bidalyx",
    "slug": "bidalyx",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "bidalyx",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F6F7F9"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
